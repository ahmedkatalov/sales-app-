# ВНИМАНИЕ: этот файл — шаблон. Скопируй в .env и заполни своими данными.
# .env НЕ должен попадать в git!

# OpenRouter API-ключ — вставь свой ключ здесь
OPENAI_API_KEY=sk-or-v1-ВСТАВЬ_СВОЙ_КЛЮЧ

OPENAI_MODEL=~anthropic/claude-sonnet-latest
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# CORS: разрешённые домены через запятую.
# Для разработки оставь пустым — будет дефолт localhost:5173.
# Для продакшена: ALLOWED_ORIGINS=https://myapp.com
ALLOWED_ORIGINS=

# URL бэкенда для фронтенда (Vite).
VITE_API_URL=http://okvionsales.ru

# Super Admin токен — придумай свой длинный секретный токен
SUPER_ADMIN_TOKEN=Q@8a9k2h8m7e8d3